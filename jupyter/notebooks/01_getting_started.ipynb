   "source": [
    "# 🚀 AI Dev Stack - Getting Started\n",
    "\n",
    "Welcome to your Apple Silicon optimized AI development environment!\n",
    "\n",
    "This notebook will help you get familiar with the tools and capabilities available in your Docker-based AI stack."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📦 Environment Check\n",
    "\n",
    "Let's first verify that all our AI libraries are properly installed and working."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Check Python version and architecture\n",
    "import sys\n",
    "import platform\n",
    "\n",
    "print(f\"Python version: {sys.version}\")\n",
    "print(f\"Platform: {platform.platform()}\")\n",
    "print(f\"Architecture: {platform.machine()}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Import and check core AI libraries\n",
    "import torch\n",
    "import transformers\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "print(f\"✅ PyTorch: {torch.__version__}\")\n",
    "print(f\"✅ Transformers: {transformers.__version__}\")\n",
    "print(f\"✅ NumPy: {np.__version__}\")\n",
    "print(f\"✅ Pandas: {pd.__version__}\")\n",
    "\n",
    "# Check available compute devices\n",
    "if torch.cuda.is_available():\n",
    "    print(\"✅ CUDA GPU is available!\")\n",
    "    device = torch.device(\"cuda\")\n",
    "else:\n",
    "    print(\"ℹ️  Using CPU (normal in Docker containers)\")\n",
    "    device = torch.device(\"cpu\")\n",
    "\n",
    "print(f\"Using device: {device}\")
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🤖 Test AI Models\n",
    "\n",
    "Let's test some basic AI functionality with pre-trained models."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test text generation with a simple model\n",
    "from transformers import pipeline\n",
    "\n",
    "# Create a text generation pipeline\n",
    "generator = pipeline('text-generation', model='distilgpt2', device=0 if torch.cuda.is_available() else -1)\n",
    "\n",
    "# Generate some text\n",
    "prompt = \"AI development on Apple Silicon is\"\n",
    "result = generator(prompt, max_length=50, num_return_sequences=1)\n",
    "\n",
    "print(f\"Prompt: {prompt}\")\n",
    "print(f\"Generated: {result[0]['generated_text']}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test sentence embeddings\n",
    "from sentence_transformers import SentenceTransformer\n",
    "\n",
    "# Load a sentence transformer model\n",
    "model = SentenceTransformer('all-MiniLM-L6-v2')\n",
    "\n",
    "# Example sentences\n",
    "sentences = [\n",
    "    \"AI development is exciting\",\n",
    "    \"Machine learning on Apple Silicon\",\n",
    "    \"Docker containers for AI\",\n",
    "    \"Python programming\"\n",
    "]\n",
    "\n",
    "# Generate embeddings\n",
    "embeddings = model.encode(sentences)\n",
    "\n",
    "print(f\"Generated embeddings for {len(sentences)} sentences\")\n",
    "print(f\"Embedding shape: {embeddings.shape}\")\n",
    "\n",
    "# Compute similarity matrix\n",
    "from sklearn.metrics.pairwise import cosine_similarity\n",
    "\n",
    "similarity_matrix = cosine_similarity(embeddings)\n",
    "print(\"\\nSimilarity Matrix:\")\n",
    "df_sim = pd.DataFrame(similarity_matrix, index=sentences, columns=sentences)\n",
    "print(df_sim.round(3))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🌐 Test API Integration\n",
    "\n",
    "Let's test the connection to our FastAPI server."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import requests\n",
    "import json\n",
    "\n",
    "# API base URL (internal Docker network)\n",
    "API_BASE = \"http://api-server:8000\"\n",
    "\n",
    "# Test API health\n",
    "try:\n",
    "    response = requests.get(f\"{API_BASE}/health\")\n",
    "    if response.status_code == 200:\n",
    "        health_data = response.json()\n",
    "        print(\"✅ API is healthy!\")\n",
    "        print(json.dumps(health_data, indent=2))\n",
    "    else:\n",
    "        print(f\"❌ API health check failed: {response.status_code}\")\n",
    "except Exception as e:\n",
    "    print(f\"❌ Could not connect to API: {e}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test text generation via API\n",
    "try:\n",
    "    response = requests.post(\n",
    "        f\"{API_BASE}/generate\",\n",
    "        json={\"text\": \"Docker and AI development\"}\n",
    "    )\n",
    "    \n",
    "    if response.status_code == 200:\n",
    "        result = response.json()\n",
    "        print(\"✅ Text generation successful!\")\n",
    "        print(f\"Generated: {result['result']}\")\n",
    "    else:\n",
    "        print(f\"❌ Generation failed: {response.status_code}\")\n",
    "        \n",
    "except Exception as e:\n",
    "    print(f\"❌ API error: {e}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📊 Data Visualization\n",
    "\n",
    "Let's create some visualizations to test our plotting capabilities."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create sample data and visualizations\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import numpy as np\n",
    "\n",
    "# Set style\n",
    "plt.style.use('seaborn-v0_8')\n",
    "sns.set_palette(\"husl\")\n",
    "\n",
    "# Generate sample AI performance data\n",
    "models = ['DistilGPT2', 'MiniLM-L6', 'Custom Model', 'BERT-Base']\n",
    "performance = [0.85, 0.92, 0.78, 0.88]\n",
    "latency = [120, 45, 200, 95]  # milliseconds\n",
    "\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(12, 5))\n",
    "\n",
    "# Performance chart\n",
    "ax1.bar(models, performance, color='skyblue')\n",
    "ax1.set_title('Model Performance Scores')\n",
    "ax1.set_ylabel('Performance Score')\n",
    "ax1.set_ylim(0, 1)\n",
    "\n",
    "# Latency chart\n",
    "ax2.bar(models, latency, color='lightcoral')\n",
    "ax2.set_title('Model Inference Latency')\n",
    "ax2.set_ylabel('Latency (ms)')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"✅ Visualization test complete!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🔍 Vector Database Test\n",
    "\n",
    "Let's test our ChromaDB vector database integration."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import chromadb\n",
    "from chromadb.config import Settings\n",
    "\n",
    "# Connect to ChromaDB\n",
    "try:\n",
    "    client = chromadb.HttpClient(host=\"vector-db\", port=8000)\n",
    "    \n",
    "    # Create or get a collection\n",
    "    collection = client.get_or_create_collection(\n",
    "        name=\"ai_development_docs\",\n",
    "        metadata={\"description\": \"AI development documentation and code snippets\"}\n",
    "    )\n",
    "    \n",
    "    # Add some sample documents\n",
    "    documents = [\n",
    "        \"Docker simplifies AI development by providing consistent environments\",\n",
    "        \"Apple Silicon offers excellent performance for AI workloads\",\n",
    "        \"Jupyter notebooks are great for interactive AI development\",\n",
    "        \"Vector databases enable semantic search in AI applications\"\n",
    "    ]\n",
    "    \n",
    "    ids = [f\"doc_{i}\" for i in range(len(documents))]\n",
    "    \n",
    "    # Add documents to collection\n",
    "    collection.add(\n",
    "        documents=documents,\n",
    "        ids=ids\n",
    "    )\n",
    "    \n",
    "    print(f\"✅ Added {len(documents)} documents to ChromaDB\")\n",
    "    \n",
    "    # Test semantic search\n",
    "    query = \"performance optimization\"\n",
    "    results = collection.query(\n",
    "        query_texts=[query],\n",
    "        n_results=2\n",
    "    )\n",
    "    \n",
    "    print(f\"\\n🔍 Search results for '{query}':\")\n",
    "    for i, doc in enumerate(results['documents'][0]):\n",
    "        distance = results['distances'][0][i]\n",
    "        print(f\"  {i+1}. {doc} (distance: {distance:.3f})\")\n",
    "        \n",
    "except Exception as e:\n",
    "    print(f\"❌ ChromaDB error: {e}\")\n",
    "    print(\"Make sure the vector-db service is running\")"
   ]
  },
  {
