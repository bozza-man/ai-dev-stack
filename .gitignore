# Docker
*.log
.docker/

# Data files (keep structure, ignore content)
data/*
!data/.gitkeep
models/*
!models/.gitkeep
!models/README.md

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# Dependency directories
node_modules/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Environment variables
.env.local
.env.development.local
.env.test.local
.env.production.local

# Temporary files
*.tmp
*.temp
.tmp/
.temp/

# Build metadata from Docker Bake
build-metadata-*.json
*.sarif

# MLflow artifacts (when running locally)
mlruns/
mlartifacts/

# Security scan results
trivy-*.json
trivy-*.sarif

# SBOM files
sbom-*.json
sbom-*.spdx.json

# Backup files
*.bak
*.backup
*~

# OS generated files
Thumbs.db
ehthumbs.db

# IDE files
*.swp
*.swo
*~

# Local development overrides
docker-compose.override.yml
docker-compose.local.yml

# Secrets and private keys (double-check these never get committed)
*.pem
*.key
*.p12
*.pfx
secrets/
.secrets

# Test artifacts
test-results/
coverage/

# Local configuration
.local/
local.properties

# Database files (if any local DBs)
*.db
*.sqlite
*.sqlite3

# Cache directories
.cache/
.pytest_cache/
.mypy_cache/
.tox/

# Documentation build
docs/_build/
site/

# Package managers
package-lock.json
yarn.lock
poetry.lock
Pipfile.lock

